# Free, INSTANT signup at https://app.duffel.com/join — create a test
# access token under Developers > Access tokens. Powers real flight and
# hotel pricing. Without it, the app falls back to simulated pricing
# automatically. (Amadeus's self-service portal paused new signups and
# shuts down July 17, 2026, so this replaced it.)
DUFFEL_ACCESS_TOKEN=

# Free, INSTANT signup at https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
# (different from the affiliate program below) — powers live, real tour
# dates on the /book page instead of the static researched list. Without
# this, the app falls back to the static list automatically.
TICKETMASTER_API_KEY=

# Apply to Ticketmaster's affiliate program (via Impact Radius) to earn a
# referral fee on ticket links. Without this, ticket links still work,
# just without attribution.
NEXT_PUBLIC_TICKETMASTER_AFFILIATE_ID=

# Apply to Skyscanner's affiliate program (via Impact) at
# https://www.partners.skyscanner.net/product/affiliates to earn referral
# fees on flight booking links. Without this, links still work.
NEXT_PUBLIC_SKYSCANNER_AFFILIATE_ID=

# Apply to Booking.com's affiliate program (via Awin in the US, CJ in
# Europe) at https://www.booking.com/affiliate-program/v2/index.html to
# earn referral fees on hotel booking links. Without this, links still work.
NEXT_PUBLIC_BOOKING_AFFILIATE_ID=

# Free signup at https://console.anthropic.com — create an API key to power
# the AI-generated "Eat & do" local guide (free) and the full day-by-day
# itinerary add-on (paid, $25). Without it, static sample content is shown
# for both instead.
ANTHROPIC_API_KEY=
